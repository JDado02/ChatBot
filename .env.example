# Copia questo file in `.env` e personalizza i valori.
# In locale puoi lasciare i default. In produzione usa password forti e segrete.

# --- PostgreSQL ---
POSTGRES_DB=concierge
POSTGRES_PORT=5432

# Superuser: usato SOLO per amministrazione/migrazioni. Bypassa la RLS.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres_dev_only

# Ruolo applicativo NON-superuser 'app_user': quello con cui si connette il
# backend. È soggetto alla Row-Level Security: garanzia che l'isolamento tra
# hotel valga. Il nome del ruolo è fisso ('app_user'); qui configuri la password.
APP_DB_PASSWORD=app_dev_only

# --- Redis ---
REDIS_PORT=6379
REDIS_HOST=localhost
# TTL delle conversazioni (secondi): scadono da sole (privacy).
CONVERSATION_TTL_SECONDS=3600

# --- Backend / connessione DB dell'app ---
DB_HOST=localhost
APP_DB_USER=app_user

# --- Modelli locali (Ollama in dev) ---
OLLAMA_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
CHAT_MODEL=llama3

# --- Sicurezza API / widget ---
# In PRODUZIONE: valore lungo e segreto, MAI questo default.
SESSION_SECRET=dev-session-secret-change-me
SESSION_TTL_SECONDS=300
RATE_LIMIT=60
RATE_WINDOW_SECONDS=60
# CORS: origini permesse al browser (lista separata da virgole). La sicurezza
# vera è server-side (allowlist domini). "*" va bene in dev.
CORS_ALLOW_ORIGINS=*
