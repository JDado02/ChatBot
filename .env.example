# Copia questo file in `.env` e personalizza i valori.
# In locale puoi lasciare i default. In produzione usa password forti e segrete.

# --- PostgreSQL ---
POSTGRES_DB=concierge
POSTGRES_PORT=5432

# Superuser: usato SOLO per amministrazione/migrazioni. Bypassa la RLS.
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres_dev_only

# Ruolo applicativo NON-superuser 'app_user': quello con cui si connette il
# backend. È soggetto alla Row-Level Security: garanzia che l'isolamento tra
# hotel valga. Il nome del ruolo è fisso ('app_user'); qui configuri la password.
APP_DB_PASSWORD=app_dev_only

# --- Redis ---
REDIS_PORT=6379
